/* 测试: 无参过程调用 + 基本乘法算法
   输入: 无 (常量 m=7, n=85)
   输出: 无 (结果存在 z, 本测试不写 write)
   预期: z = 7*85 = 595, 无错误 */
const m=7, n=85;
var x,y,z,q,r;
procedure multiply;
    var a,b;
    begin
        a:=x; b:=y; z:=0;
        while b>0 do
            begin
                if odd b then z:=z+a;
                a:=2*a; b:=b/2;
            end
    end;
begin
    x:=m; y:=n;
    call multiply;
end.
